<odoo>

    <record id="inherit_choose_delivery_carrier_view_form" model="ir.ui.view">
        <field name="name">choose.delivery.carrier.fedex.form</field>
        <field name="model">choose.delivery.carrier</field>
        <field name="inherit_id" ref="delivery.choose_delivery_carrier_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//group" position="after">

                <field name="fedex_rate_line_ids"
                       invisible="delivery_type != 'fedex'"
                       readonly="1"
                       options="{'no_create': True, 'no_open': True}">

                    <list create="0" edit="0" delete="0">

                        <field name="service_name"/>
                        <field name="service_code"/>
                        <field name="amount"/>
                        <field name="currency_id"/>
                        <field name="delivery_days"/>

                    </list>

                </field>

            </xpath>

        </field>
    </record>


    <record id="view_choose_delivery_carrier_fedex" model="ir.ui.view">
        <field name="name">choose.delivery.carrier.fedex</field>
        <field name="model">choose.delivery.carrier</field>
        <field name="inherit_id" ref="delivery.choose_delivery_carrier_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//footer" position="attributes">
                <attribute name="invisible">delivery_type == 'fedex'</attribute>
            </xpath>

        </field>
    </record>


</odoo>