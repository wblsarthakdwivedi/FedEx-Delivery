<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="view_delivery_carrier_form_fedex"
            model="ir.ui.view">

        <field name="name">delivery.carrier.form.fedex</field>

        <field name="model">delivery.carrier</field>

        <field name="inherit_id"
               ref="delivery.view_delivery_carrier_form"/>

        <field name="arch" type="xml">

            <xpath expr="//page[@name='destination']"
                   position="after">

                <page string="FedEx Credentials"
                      name="fedex_config"
                      invisible="delivery_type != 'fedex'">

                    <group>

                        <field name="fedex_api_key"
                               required="True"/>
                        <field name="fedex_secret_key"
                               required="True"/>

                        <field name="fedex_account"
                               required="True"/>

                    </group>
                </page>

            </xpath>

        </field>

    </record>


</odoo>