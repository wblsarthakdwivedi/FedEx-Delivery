<?xml version="1.0" encoding="UTF-8" ?>
<odoo>


    <record id="action_fedex_dashboard" model="ir.actions.client">
        <field name="name">fedex Dashboard</field>
        <field name="tag">fedex_dashboard</field>
    </record>


    <record id="action_fedex_shipping" model="ir.actions.act_window">
        <field name="name">Shipping Orders</field>
        <field name="res_model">fedex.shipping</field>
        <field name="view_mode">list,form</field>
    </record>


    <record id="action_fedex_labels" model="ir.actions.act_window">
        <field name="name">Labels</field>
        <field name="res_model">fedex.label</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('picking_id.carrier_id.delivery_type', '=', 'fedex')]</field>
    </record>


    <menuitem id="menu_root_fedex" name="FedEx Dashboard"/>

    <menuitem id="menu_wbl_fedex_dashboard"
              name="Dashboard"
              parent="menu_root_fedex"
              action="action_fedex_dashboard"
              sequence="10"/>


    <menuitem id="menu_wbl_shipping"
              name="Delivery Methods"
              parent="menu_root_fedex"
              action="delivery.action_delivery_carrier_form"
              sequence="5"/>


    <menuitem id="menu_fedex_shipping_order"
              name="Shipping Orders"
              parent="menu_root_fedex"
              action="action_fedex_shipping"
              sequence="15"/>


    <menuitem id="menu_packaging"
              name="Package Types"
              parent="menu_root_fedex"
              action="action_stock_package_type"
              sequence="20"/>
    
    
    <menuitem id="menu_fedex_shpping_label"
              name="FedEx Label"
              parent="menu_root_fedex"
              action="action_fedex_labels"
              sequence="25"/>

</odoo>